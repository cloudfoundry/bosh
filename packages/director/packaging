set -e

mkdir -p "${BOSH_INSTALL_TARGET}"/{bin,gem_home}

source /var/vcap/packages/director-ruby-4.0/bosh/compile.env

libpq_dir=/var/vcap/packages/libpq
mysqlclient_dir=/var/vcap/packages/mysql

working_dir="$(pwd)"
for gemspec in ./bosh-*/*.gemspec; do
  pushd "$(dirname "${gemspec}")"
    gem build
    mv ./*.gem "${working_dir}/vendor/cache/"
  popd
done

cat > Gemfile <<EOF
gem 'bosh-director'
gem 'mysql2'
gem 'pg'
EOF

bundle config set build.mysql2 \
  --with-mysql-config=$mysqlclient_dir/bin/mariadb_config-wrapper.sh

bundle config set build.pg \
  --with-pg-lib=$libpq_dir/lib \
  --with-pg-include=$libpq_dir/include

bosh_bundle_local
bosh_generate_runtime_env

cp -r Gemfile Gemfile.lock .bundle "${BOSH_INSTALL_TARGET}"
